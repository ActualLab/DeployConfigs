[Unit]
Description=oracle-vm1 shared edge proxy poll-based auto-deploy
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=ubuntu
Environment=REPO_DIR=/opt/apps/deploy-configs
Environment=BRANCH=main
# Invoke via bash so it runs regardless of the file's executable bit
ExecStart=/bin/bash /opt/apps/deploy-configs/oracle-vm1/edge/deploy.sh
